# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright & agent verification artifacts (root only)
/*.png
/*.jpg
/*.jpeg
.playwright-mcp/
.agent/
screenshots/
/playground/

# Diagnostic & verification reports
RESUMEN_DIAGNOSTICO.txt
network-requests.txt
*.txt

# Agent documentation (internal only, not for git)
QUICK_REFERENCE*

# IDE & debugging
.vscode/
.idea/

services.json