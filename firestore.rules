rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Products: public read, admin write ────────────────────────────────────
    // Products can be read by anyone (public catalog)
    // Only admins can create, update, or delete products
    match /products/{document=**} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Featured Products: public read, admin write ────────────────────────────
    // Featured products can be read by anyone
    // Only admins can manage featured products
    match /featured_products/{document=**} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Admin Users: admin only ───────────────────────────────────────────────
    // Only admins can read or manage admin users
    match /admin_users/{document=**} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Admin OTPs: admin only (server-side management) ───────────────────────
    // OTP codes are managed server-side and must not be readable by clients
    // Only admins can read/write (for server-side operations)
    match /admin_otps/{document=**} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // ── OTP Attempts: admin only ──────────────────────────────────────────────
    // Rate limiting data for OTP verification attempts
    // Only admins can access (server-side management)
    match /otp_attempts/{document=**} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Admin Phones Config: admin read only ──────────────────────────────────
    // Phone numbers for admin OTP delivery (configuration data)
    // Admins can read for initialization, no client writes allowed
    match /admin_phones/{document=**} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false; // Managed only via Firebase Admin SDK / CLI
    }

    // ── Services: public read, admin write ────────────────────────────────────
    // Services can be read by anyone
    // Only admins can manage services
    match /services/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // ── Default deny all ──────────────────────────────────────────────────────
    // Any collection not explicitly allowed above is denied by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
